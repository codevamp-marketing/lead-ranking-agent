# ── Secrets — NEVER bake into image ──────────────────────────────────────────
.env
.env.*
*.env

# ── Git ───────────────────────────────────────────────────────────────────────
.git
.gitignore

# ── Python cache — rebuilt inside container ───────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log

# ── SQL scripts — only needed for DB setup, not runtime ──────────────────────
sql/

# ── Docs — not needed in container ───────────────────────────────────────────
README.md
*.md

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db